{
  "name": "@fsegurai/test-package-0",
  "version": "1.0.0-alpha.lib.12",
  "description": "A simple, framework-agnostic Scrollspy script for navigation and table of contents.",
  "type": "module",
  "license": "MIT",
  "author": {
    "name": "Fabián Segura",
    "url": "https://fsegurai.com"
  },
  "engines": {
    "node": ">=22",
    "bun": ">=1.3.0",
    "npm": ">=10"
  },
  "keywords": [
    "accessibility",
    "framework-agnostic",
    "javascript",
    "javascript-library",
    "lightweight",
    "library",
    "navigation",
    "scrollspy",
    "scroll",
    "table-of-contents",
    "toc",
    "typescript",
    "typescript-library"
  ],
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "prebuild": "bun run clean",
    "build": "bun run build:packages && bun run postbuild:packages && bun run build:demo && bun run postbuild:demo",
    "postbuild:demo": "cp ./README.md ./demo/dist/README.md && cp ./LICENSE ./demo/dist/LICENSE",
    "postbuild:packages": "find ./packages -maxdepth 1 -type d ! -name '.helper' ! -name 'packages' -exec cp ./LICENSE {} \\; -exec cp ./README.md {} \\;",
    "build:packages": "bun run --filter '*' pkg:build",
    "build:demo": "vite build",
    "build:demo:dev": "vite dev",
    "build:doppler": "doppler run bun run build",
    "build:packages:doppler": "doppler run bun run build:packages && bun run postbuild:packages",
    "build:demo:doppler": "doppler run bun run build:demo && bun run postbuild:demo",
    "clean": "bun run clean:packages && bun run clean:demo",
    "clean:packages": "rimraf --glob ./packages/*/dist && rimraf --glob ./packages/*/LICENSE",
    "clean:demo": "rimraf --glob ./demo/dist ./demo/README.md ./demo/LICENSE",
    "clean:coverage": "rimraf --glob ./coverage",
    "dev": "portless run vite serve",
    "dev:doppler": "doppler run bun run dev",
    "start": "bun run dev",
    "start:doppler": "bun run dev:doppler",
    "test": "bun run --filter '*' pkg:test",
    "test:coverage": "bun test --coverage",
    "test:snapshots": "bun test --update-snapshots",
    "test:summary": "bun run ./scripts/test-all-packages.ts --summary",
    "test:packages": "bun run --filter '*' pkg:test:coverage",
    "test:packages:snapshots": "bun run --filter '*' pkg:test -- --update-snapshots",
    "lint": "bun run lint:packages && bun run lint:demo",
    "lint:check": "eslint . --max-warnings 0",
    "lint:fix": "bun run lint:packages --fix && bun run lint:demo --fix",
    "lint:packages": "eslint ./packages/*/src/**",
    "lint:demo": "eslint ./demo"
  },
  "dependencies": {
    "@fsegurai/test-package-1": "workspace:*",
    "@material/web": "^2.4.1",
    "clipboard": "^2.0.11",
    "marked": "^18.0.0",
    "marked-highlight": "^2.2.4",
    "prismjs": "^1.30.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.6.0",
    "@types/prismjs": "^1.26.6",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "bun-types": "^1.3.12",
    "eslint": "^10.2.0",
    "globals": "^17.5.0",
    "jsdom": "^29.0.2",
    "portless": "^0.10.3",
    "rimraf": "^6.1.3",
    "terser": "^5.46.1",
    "typescript": "6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.8"
  }
}
